OFFERPATH_APP_NAME=OfferPath
OFFERPATH_ENV=local
OFFERPATH_DATABASE_URL=sqlite:///./offerpath.db
OFFERPATH_REDIS_URL=redis://localhost:6379/0
OFFERPATH_AI_PROVIDER=mock
OFFERPATH_GEMINI_MODEL=gemini-2.0-flash-lite
# OFFERPATH_GEMINI_API_KEY=replace-with-a-local-secret
OFFERPATH_OPENAI_MODEL=gpt-4o-mini
# OFFERPATH_OPENAI_API_KEY=replace-with-a-local-secret
OFFERPATH_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174
STORAGE_BACKEND=s3
AWS_REGION=ap-southeast-2
S3_BUCKET_NAME=your-bucket-name
S3_RESUME_PREFIX=resumes
# Optional for local personal AWS credentials. Prefer EC2/ECS IAM roles in production.
# AWS_ACCESS_KEY_ID=replace-with-local-access-key
# AWS_SECRET_ACCESS_KEY=replace-with-local-secret-key
OFFERPATH_SECRET_KEY=change-me-in-production
OFFERPATH_ACCESS_TOKEN_EXPIRE_MINUTES=1440
OFFERPATH_UPLOAD_DIR=./storage/resumes
OFFERPATH_LOG_LEVEL=INFO
